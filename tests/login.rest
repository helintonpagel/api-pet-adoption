@baseUrl = http://localhost:3000

### 1. Login com sucesso (Administrador)
# Deve retornar o token JWT e os dados do usuário (sem a senha).
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@email.com",
  "password": "123456"
}

### 2. Login com sucesso (Usuário Comum / Adopter)
# Deve retornar o token JWT e os dados do usuário (sem a senha).
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "joao@email.com",
  "password": "123456"
}

### 3. Falha no Login (Senha Incorreta)
# Deve retornar erro 401 - Credenciais inválidas.
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@email.com",
  "password": "senha_errada_123"
}

### 4. Falha no Login (E-mail Inexistente)
# Deve retornar erro 401 - Credenciais inválidas.
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "usuario_fantasma@email.com",
  "password": "123456"
}